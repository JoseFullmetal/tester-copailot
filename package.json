{
  "name": "registro-estudiantes-tests",
  "version": "1.0.0",
  "description": "Pruebas unitarias para formulario de registro de estudiantes universitarios",
  "main": "index.html",
  "scripts": {
    "serve": "npx http-server . -p 3000",
    "test:unit": "jest tests/unit",
    "test": "npm run test:unit",
    "test:watch": "jest --watch tests/unit",
    "test:coverage": "jest --coverage tests/unit",
    "test:verbose": "jest --verbose tests/unit",
    "cypress:open": "npx cypress open",
    "cypress:run": "npx cypress run",
    "test:e2e": "npx start-server-and-test serve http://localhost:3000 cypress:run",
    "ci:test": "npm run test:unit && npm run test:e2e"
  },
  "keywords": [
    "formulario",
    "validación",
    "pruebas",
    "jest",
    "estudiantes"
  ],
  "author": "Tu Nombre",
  "license": "MIT",
  "devDependencies": {
    "cypress": "^15.13.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "start-server-and-test": "^1.14.0"
  }
}
